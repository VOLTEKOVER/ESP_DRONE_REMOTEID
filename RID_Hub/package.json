{
  "name": "rid-hub",
  "version": "1.0.0",
  "description": "RID Hub — Open DroneID Ground Station",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.votekover.rid-hub",
    "productName": "RID Hub",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "rid_hub/**/*",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "rid_hub/web/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "rid_hub/web/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "rid_hub/web/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}

# ==================== PROJECT SPECIFIC ====================
# Skip sensitive config files
config.local.json

# Don't commit compiled examples
firmware/examples/**/build/
firmware/ESP32_DRONE_ID/build/
firmware/id_open/build/

# Skip VSCode workspace settings (keep only repo settings)
.vscode/*.json
!.vscode/settings.json
